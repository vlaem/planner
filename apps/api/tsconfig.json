{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "./types/vitest.shims.d.ts"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "#src/*": ["./src/*"],
      "#infra/*": ["./src/infra/*"],
      "#domain/*": ["./src/domain/*"],
      "#api/*": ["./src/api/*"],
      "#errors/*": ["./src/errors/*"],
      "#app/*": ["./src/app/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules"]
}
