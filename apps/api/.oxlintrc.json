{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-explicit-any": "error"
  },
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["src/**/*.spec.ts"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/unbound-method": "off"
      }
    }
  ]
}
