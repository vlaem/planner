{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "#infra/*": ["./src/infra/*"],
      "#domain/*": ["./src/domain/*"],
      "#api/*": ["./src/api/*"],
      "#errors/*": ["./src/errors/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "src/global.d.ts"],
  "exclude": ["node_modules"]
}
